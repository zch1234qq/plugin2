{
  "name": "plugin2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "yarn copy-worker && vite --host",
    "copy-worker": "node -e \"const fs=require('fs');const path=require('path');const publicDir=path.resolve('./public');if(!fs.existsSync(publicDir))fs.mkdirSync(publicDir,{recursive:true});fs.copyFileSync(path.resolve('./node_modules/pdfjs-dist/build/pdf.worker.mjs'),path.resolve(publicDir,'pdf.worker.mjs'));console.log('PDF Worker 文件已复制到 public 目录');\"",
    "build": "vite build",
    "build:windows": "tauri build --bundles nsis",
    "build:windows:x86": "tauri build --target i686-pc-windows-msvc --bundles nsis",
    "build:windows:x64": "tauri build --target x86_64-pc-windows-msvc --bundles nsis",
    "build:windows:signed": "tauri build --bundles nsis --config src-tauri/tauri.windows.sign.local.json",
    "build:windows:x86:signed": "tauri build --target i686-pc-windows-msvc --bundles nsis --config src-tauri/tauri.windows.sign.local.json",
    "build:windows:x64:signed": "tauri build --target x86_64-pc-windows-msvc --bundles nsis --config src-tauri/tauri.windows.sign.local.json",
    "build:large": "npx --node-options=\"--max-old-space-size=8192\" vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
