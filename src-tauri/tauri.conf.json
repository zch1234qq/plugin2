{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aditor个人版(不可商用)",
  "version": "0.1.1",
  "identifier": "cn.aditor.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "aditor个人版(不可商用)",
        "width": 960,
        "height": 540,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https:; media-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https: http://localhost:* ws://localhost:* http://127.0.0.1:* ws://127.0.0.1:*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.jpg"
    ]
  },
  "plugins": {
    "shell": {
      "open": "^(https?://.+|mailto:.+|tel:.+|file://.+|[a-zA-Z]:[\\\\/].+|/.+)$"
    }
  }
}
